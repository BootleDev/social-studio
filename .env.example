# social-studio runtime environment variables
#
# Copy to .env.local for local dev (.env* is gitignored). In production these
# are set in the Vercel project settings. All values below are SERVER-SIDE only
# — none are exposed to the browser, so none use a NEXT_PUBLIC_ prefix.

# --- Auth ---
# Shared password gate for the studio (middleware + requireAuth).
STUDIO_PASSWORD=

# --- Airtable (intelligence reads) ---
# Base that holds Posts / Content Library / Trend Reports / Creative Briefs etc.
# (production base id: app0oKaYjbWBcrqzH).
AIRTABLE_BASE_ID=
AIRTABLE_API_KEY=

# --- Supabase (WEBDEV-207: latest trend report read-repoint) ---
# Direct Postgres connection string (postgres://user:password@host:port/db).
# Server-side only. When set, getLatestTrendReport() reads the latest report
# from social.trend_reports and falls back to Airtable on any error or empty
# result. When unset, the trend report is read from Airtable (unchanged).
SUPABASE_DB_URL=
# Optional kill switch: set to "airtable" to force the Airtable path even when
# SUPABASE_DB_URL is present. Leave unset for the default Supabase-with-fallback.
TREND_REPORT_SOURCE=

# --- Anthropic (AI caption generation) ---
ANTHROPIC_API_KEY=

# --- Meta / Instagram publishing ---
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
# Optional, defaults to v22.0 when unset.
META_API_VERSION=

# --- Vercel Blob (media uploads) ---
# Auto-injected by Vercel in production. Set locally to test uploads.
BLOB_READ_WRITE_TOKEN=
